# ========================
# Ollive AI Assessment
# Environment Variables
# ========================

# --- Groq API ---
GROQ_API_KEY=your_groq_api_key_here

# --- OSS Model ---
OSS_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
OSS_DEVICE=auto          # auto | cpu | cuda | mps
OSS_QUANTIZATION=4bit    # 4bit | 8bit | none

# --- Hosted Model ---
HOSTED_MODEL_NAME=llama-3.3-70b-versatile
HOSTED_API_BASE=https://api.groq.com/openai/v1

# --- App Config ---
APP_ENV=development      # development | production
LOG_LEVEL=INFO
MAX_HISTORY_TURNS=10
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9

# --- Langfuse Observability (optional free tier) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Safety ---
SAFETY_MODE=strict       # strict | moderate | off
ENABLE_GUARDRAILS=true

# --- Evaluation ---
EVAL_JUDGE_MODEL=llama-3.3-70b-versatile
EVAL_OUTPUT_DIR=reports/
