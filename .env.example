# ========================
# Ollive AI Assessment
# Environment Variables
# ========================

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- OSS Model ---
OSS_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
OSS_DEVICE=cpu
OSS_QUANTIZATION=none

# --- Hosted Model ---
HOSTED_MODEL_NAME=gemini-2.5-flash

# --- App Config ---
APP_ENV=development
LOG_LEVEL=INFO
MAX_HISTORY_TURNS=10
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9

# --- Langfuse Observability (optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Safety ---
SAFETY_MODE=strict
ENABLE_GUARDRAILS=true

# --- Evaluation ---
EVAL_JUDGE_MODEL=gemini-2.5-flash
EVAL_OUTPUT_DIR=reports/
# --- LLM Judge (Groq/Llama for evaluation only) ---
GROQ_JUDGE_KEY=your_groq_api_key_here
